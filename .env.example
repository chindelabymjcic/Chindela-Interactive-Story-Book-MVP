# Core
NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://user:password@localhost:3306/chindela
SESSION_SECRET=replace-with-at-least-32-random-characters

# Admin bootstrap (see api/lib/bootstrap.ts, api/auth-router.ts)
# The first account registered with this address becomes an administrator,
# but only if it also supplies the current bootstrap token (see server logs
# on first boot, or set ADMIN_BOOTSTRAP_TOKEN below to pin it yourself).
ADMIN_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_TOKEN=

# Gemini AI tutor (Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# App base URL, used to build Stripe Checkout success/cancel redirect URLs
APP_URL=http://localhost:3000

# Stripe (use TEST MODE keys in development -- never commit live keys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# AWS S3 (media uploads)
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Resend (transactional email)
RESEND_API_KEY=
EMAIL_FROM=
